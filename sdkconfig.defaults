#
# ESP-IDF sdkconfig defaults for tinyml-demo-esp32s31
#
# These values are applied on top of the Kconfig defaults whenever
# `idf.py reconfigure` (or `idf.py build`) runs.
#

# Increase task WDT timeout from 5 s to 30 s — the LVGL port task yields
# correctly but the 5 s window is too short when the display is idle.
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30
