# Custom partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Flash size — Korvo-1 has 16 MB
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# LVGL — enable Montserrat 28 font for splash/state display
CONFIG_LV_FONT_MONTSERRAT_28=y

# PSRAM — Korvo-1 has 16 MB Octal PSRAM; required for RGB display buffers
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y
CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y

# Camera sensor — OV3660 on DVP interface
CONFIG_CAMERA_OV3660=y
# Enable RGB565 at 640×480 (closest available to QVGA with RGB output)
CONFIG_CAMERA_OV3660_DVP_RGB565_BE_640X480_10FPS=y
CONFIG_CAMERA_OV3660_DVP_DEFAULT_FMT_RGB565_BE_640X480_10FPS=y

# ESP-SR configuration
# WakeNet9 "Hi,ESP"
CONFIG_SR_WN_WN9_HIESP=y
# MultiNet7 English (command detection)
CONFIG_SR_MN_EN_MULTINET7_QUANT=y
# Use WebRTC NS (no dedicated NS model needed)
CONFIG_SR_NSN_WEBRTC=y
CONFIG_SR_VADN_WEBRTC=y
